body{
margin:0;
font-family:Arial,sans-serif;
background:#eef5ff;
}

header{
background:#0057b8;
color:white;
text-align:center;
padding:35px;
}

nav{
background:#003f88;
padding:15px;
text-align:center;
}

nav a{
color:white;
text-decoration:none;
margin:20px;
font-weight:bold;
}

.hero{
text-align:center;
padding:60px 20px;
}

.hero h2{
font-size:40px;
}

.hero button{
padding:12px 25px;
font-size:18px;
background:#0057b8;
color:white;
border:none;
border-radius:8px;
cursor:pointer;
}

.cards{
display:flex;
justify-content:center;
gap:25px;
flex-wrap:wrap;
padding:40px;
}

.card{
background:white;
width:250px;
padding:20px;
border-radius:12px;
box-shadow:0 5px 15px rgba(0,0,0,.15);
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
}

footer{
background:#003f88;
color:white;
text-align:center;
padding:20px;
margin-top:30px;
}
